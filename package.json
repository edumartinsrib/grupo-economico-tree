{
  "name": "grupo-economico-tree",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:api": "python3 -m uvicorn server.main:app --host 0.0.0.0 --port 8000",
    "generate:test-data": "python3 scripts/gerar_csvs_teste.py",
    "process:real": "scripts/reprocessar_arvore_reais.sh",
    "validate:data": "python3 scripts/reprocessar_dados_reais.py",
    "process:data": "python3 scripts/construir_rede_grupos.py",
    "refresh:data": "python3 scripts/reprocessar_dados_reais.py --process --clean --rebuild",
    "check:data": "python3 scripts/reprocessar_dados_reais.py --check-only",
    "reprocess": "python3 scripts/construir_rede_grupos.py && npm run build",
    "backend": "python3 -m uvicorn server.main:app --host 0.0.0.0 --port 8000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^4.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
